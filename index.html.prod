<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kupe · CRM</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap');
:root{
  --bg:#f5f5f5;--sur:#ffffff;--card:#ffffff;--bor:#e0e0e0;
  --acc:#e03a00;--yel:#d97700;--grn:#00a65a;--org:#c05a00;--red:#cc2222;--blu:#1a73e8;
  --txt:#1a1a1a;--mu:#aaa;--mu2:#777;--shadow:0 1px 4px rgba(0,0,0,.08)
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--txt);font-family:'DM Sans',sans-serif;padding-bottom:40px}
.hdr{background:var(--sur);border-bottom:2px solid var(--acc);padding:12px 18px 10px;position:sticky;top:0;z-index:200;box-shadow:var(--shadow)}
.hdr-top{display:flex;align-items:center;gap:10px;margin-bottom:7px}
.logo{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--acc);letter-spacing:3px;line-height:1}
.logo em{color:var(--yel);font-style:normal}
.tag{background:var(--acc);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;letter-spacing:1.5px;text-transform:uppercase}
.status-bar{display:flex;gap:7px;flex-wrap:wrap}
.status-pill{display:flex;align-items:center;gap:5px;background:var(--bg);border:1px solid var(--bor);border-radius:8px;padding:4px 9px;font-size:10px;cursor:pointer;transition:border-color .2s}
.status-pill:hover{border-color:#bbb}
.status-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.status-label{color:var(--mu2)}
.status-val{color:var(--txt);font-weight:600}
.status-pill.warn .status-dot{background:var(--yel)}
.status-pill.ok .status-dot{background:var(--grn)}
.status-pill.info .status-dot{background:var(--blu)}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;align-items:flex-end}
.modal-bg.open{display:flex}
.modal{background:#fff;border-top:2px solid var(--acc);border-radius:16px 16px 0 0;padding:20px 18px 32px;width:100%;max-height:85vh;overflow-y:auto}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;margin-bottom:3px;color:var(--acc)}
.modal-sub{font-size:11px;color:var(--mu2);margin-bottom:14px}
.modal-close{float:right;background:none;border:none;color:var(--mu2);font-size:22px;cursor:pointer;margin-top:-4px}
.file-row{background:var(--bg);border:1px solid var(--bor);border-radius:10px;padding:11px 13px;margin-bottom:8px}
.file-name{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:3px}
.file-period{font-size:11px;color:var(--mu2)}
.file-period b{color:var(--yel)}
.file-rows{font-size:10px;color:var(--mu);margin-top:2px}
.modal-hint{background:#fff8ec;border:1px solid #ffd580;border-radius:8px;padding:10px 12px;font-size:11px;color:#7a5000;line-height:1.6;margin-top:12px}
.tabs{display:flex;background:#fff;border-bottom:1px solid var(--bor);position:sticky;top:96px;z-index:199;overflow-x:auto;scrollbar-width:none;box-shadow:var(--shadow)}
.tabs::-webkit-scrollbar{display:none}
.tab{flex:1;min-width:64px;padding:10px 4px 8px;text-align:center;font-size:9px;font-weight:600;color:var(--mu2);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.tab.active{color:var(--acc);border-bottom-color:var(--acc)}
.ti{display:block;font-size:16px;margin-bottom:2px}
.pg{display:none;padding:14px}.pg.active{display:block}
.sec{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:2px;color:var(--mu2);margin:16px 0 10px;border-left:3px solid var(--acc);padding-left:9px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:12px}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:12px}
.card{background:var(--sur);border:1px solid var(--bor);border-radius:11px;padding:12px 13px;box-shadow:var(--shadow)}
.cl{font-size:9px;color:var(--mu);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:3px}
.cv{font-family:'Bebas Neue',sans-serif;font-size:28px;line-height:1}
.cs{font-size:10px;color:var(--mu2);margin-top:3px}
.cva{color:var(--acc)}.cvy{color:var(--yel)}.cvg{color:var(--grn)}.cvr{color:var(--red)}.cvb{color:var(--blu)}
.dt{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:600;padding:2px 6px;border-radius:5px;margin-top:4px}
.dp{background:#e8f8f0;color:var(--grn)}.dn{background:#fdecea;color:var(--red)}.dy{background:#fff3dc;color:var(--yel)}
.ale{background:#fff3ef;border:1px solid #ffc5b0;border-radius:10px;padding:11px 13px;margin-bottom:12px;font-size:12px;line-height:1.65;color:#7a2a00}
.ale b{color:var(--acc)}
.ale-g{background:#edfbf4;border:1px solid #a3e6c5;border-radius:10px;padding:11px 13px;margin-bottom:12px;font-size:12px;line-height:1.65;color:#00532c}
.ale-g b{color:var(--grn)}
.cb{background:var(--sur);border:1px solid var(--bor);border-radius:11px;padding:13px;margin-bottom:12px;box-shadow:var(--shadow)}
.ct{font-size:11px;font-weight:600;color:var(--mu2);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px}
.pr{background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:11px 13px;margin-bottom:7px;box-shadow:var(--shadow)}
.pt{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:7px}
.pn{font-size:12px;font-weight:600;max-width:60%;line-height:1.3;color:var(--txt)}
.pu{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--acc);text-align:right}
.pi{font-size:10px;color:var(--mu2);text-align:right}
</style>
</head>
<body>
<div class="hdr">
  <div class="hdr-top">
    <div class="logo">KUPE<em>.</em></div>
    <span class="tag">CRM · ETAPA 1</span>
  </div>
  <div class="status-bar">
    <div class="status-pill ok">
      <div class="status-dot"></div>
      <span class="status-label">Datos cargados desde</span>
      <span class="status-val" id="statusDate">Supabase</span>
    </div>
    <div class="status-pill info">
      <div class="status-dot"></div>
      <span class="status-label">Mes actual</span>
      <span class="status-val" id="statusMes">--</span>
    </div>
  </div>
</div>

<div class="tabs">
  <div class="tab active" onclick="goTab('evo',this)"><span class="ti">📈</span>Evolución</div>
  <div class="tab" onclick="goTab('mar',this)"><span class="ti">🔥</span>Marzo</div>
  <div class="tab" onclick="goTab('prod',this)"><span class="ti">🍔</span>Productos</div>
</div>

<div id="pg-evo" class="pg active">
  <div class="ale-g"><b>✅ Etapa 1 activa:</b> Datos dinámicos desde Supabase. MON, MAR_PRODS, MAR_PEDS, PRODS en tiempo real.</div>
  <div class="sec">PEDIDOS / MES · ÚLTIMOS 12 MESES</div>
  <div class="cb"><div class="ct">Histórico dinámico</div><canvas id="cP" height="175"></canvas></div>
</div>

<div id="pg-mar" class="pg">
  <div class="ale"><b>🔥 Marzo dinámico:</b> Datos actualizados en tiempo real desde la Edge Function.</div>
  <div class="sec">TOP 10 PRODUCTOS MARZO</div>
  <div id="plist-mar"></div>
  <div class="sec">PEDIDOS POR DÍA</div>
  <div class="cb"><div class="ct">Marzo actual</div><canvas id="cMar" height="165"></canvas></div>
</div>

<div id="pg-prod" class="pg">
  <div class="ale"><b>Histórico consolidado:</b> Suma total de todos los artículos desde el inicio de datos.</div>
  <div class="sec">TOP 15 · HISTÓRICO COMPLETO</div>
  <div id="plist"></div>
</div>

<script>
// ============================================================
// ETAPA 1: FETCH DINÁMICO DESDE EDGE FUNCTION
// ============================================================
const EDGE_FUNCTION_URL = 'https://lqpzhzworncmcuptesjh.supabase.co/functions/v1/crm-data';
let crmData = null;

async function fetchCRMData(mes = null) {
  try {
    let url = EDGE_FUNCTION_URL;
    if (mes) {
      url += `?mes=${mes}`;
    }

    console.log('🔄 Fetch desde:', url);

    const response = await fetch(url, {
      method: 'GET',
      headers: { 'Content-Type': 'application/json' },
      mode: 'cors',
    });

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    crmData = await response.json();
    console.log('✅ Datos cargados:', crmData);
    return crmData;
  } catch (error) {
    console.error('❌ Error fetch:', error);
    return null;
  }
}

// ============================================================
// UPDATE FUNCTIONS
// ============================================================

function updateChartMeses() {
  if (!crmData || !crmData.MON) return;
  const ctx = document.getElementById('cP');
  if (!ctx) return;

  if (window.chartMonths) {
    window.chartMonths.destroy();
  }

  window.chartMonths = new Chart(ctx.getContext('2d'), {
    type: 'line',
    data: {
      labels: crmData.MON.meses,
      datasets: [
        {
          label: 'Pedidos',
          data: crmData.MON.pedidos,
          borderColor: '#FF6B6B',
          backgroundColor: 'rgba(255, 107, 107, 0.1)',
          tension: 0.3,
          yAxisID: 'y',
        },
        {
          label: 'Revenue',
          data: crmData.MON.revenue,
          borderColor: '#4ECDC4',
          backgroundColor: 'rgba(78, 205, 196, 0.1)',
          tension: 0.3,
          yAxisID: 'y1',
        },
        {
          label: 'Ticket Promedio',
          data: crmData.MON.ticket_promedio,
          borderColor: '#FFE66D',
          backgroundColor: 'rgba(255, 230, 109, 0.1)',
          tension: 0.3,
          yAxisID: 'y2',
        },
        {
          label: 'Clientes Únicos',
          data: crmData.MON.clientes_unicos,
          borderColor: '#A8E6CF',
          backgroundColor: 'rgba(168, 230, 207, 0.1)',
          tension: 0.3,
          yAxisID: 'y',
        },
      ],
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: true, position: 'bottom' },
        title: { display: true, text: 'Evolución: 12 meses · 4 métricas' },
      },
      scales: {
        y: {
          type: 'linear',
          display: true,
          position: 'left',
          title: { display: true, text: 'Pedidos / Clientes' },
        },
        y1: {
          type: 'linear',
          display: true,
          position: 'right',
          title: { display: true, text: 'Revenue ($)' },
          grid: { drawOnChartArea: false },
        },
        y2: {
          type: 'linear',
          display: true,
          position: 'right',
          title: { display: true, text: 'Ticket Promedio ($)' },
          grid: { drawOnChartArea: false },
        },
      },
    },
  });
}

function updateTableMarProds() {
  if (!crmData || !crmData.MAR_PRODS) return;

  const container = document.getElementById('plist-mar');
  if (!container) return;

  container.innerHTML = crmData.MAR_PRODS.map((row, i) => `
    <div class="pr">
      <div class="pt">
        <div class="pn">#${i + 1} ${row.articulo}</div>
        <div class="pu">${row.cantidad}</div>
      </div>
      <div class="pi">$${row.total.toLocaleString('es-AR')}</div>
    </div>
  `).join('');
}

function updateChartMarPeds() {
  if (!crmData || !crmData.MAR_PEDS || !crmData.MAR_DIAS) return;

  const ctx = document.getElementById('cMar');
  if (!ctx) return;

  if (window.chartMarPeds) {
    window.chartMarPeds.destroy();
  }

  window.chartMarPeds = new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: {
      labels: crmData.MAR_DIAS,
      datasets: [
        {
          label: 'Pedidos',
          data: crmData.MAR_PEDS.map(p => p.pedidos),
          backgroundColor: '#FF6B6B',
          borderColor: '#FF6B6B',
          borderWidth: 1,
        },
      ],
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: true, position: 'bottom' },
        title: { display: true, text: `Pedidos por día - ${crmData.mes_actual}` },
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { stepSize: 1 },
        },
      },
    },
  });
}

function updateTableProds() {
  if (!crmData || !crmData.PRODS) return;

  const container = document.getElementById('plist');
  if (!container) return;

  container.innerHTML = crmData.PRODS.slice(0, 15).map((row, i) => `
    <div class="pr">
      <div class="pt">
        <div class="pn">#${i + 1} ${row.articulo}</div>
        <div class="pu">${row.cantidad_total}</div>
      </div>
      <div class="pi">$${row.total_revenue.toLocaleString('es-AR')}</div>
    </div>
  `).join('');
}

function goTab(tabName, element) {
  document.querySelectorAll('.pg').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('pg-' + tabName)?.classList.add('active');
  element.classList.add('active');
}

document.addEventListener('DOMContentLoaded', async function() {
  console.log('🚀 Iniciando Etapa 1...');

  await fetchCRMData();

  if (crmData) {
    document.getElementById('statusDate').textContent = new Date(crmData.timestamp).toLocaleDateString('es-AR');
    document.getElementById('statusMes').textContent = crmData.mes_actual || '--';

    updateChartMeses();
    updateTableMarProds();
    updateChartMarPeds();
    updateTableProds();

    console.log('✅ Etapa 1 lista.');
  } else {
    console.warn('⚠️ No se pudieron cargar los datos.');
  }
});
</script>

</body>
</html>
